    "db:usuarios": "node scripts/ver-registros.js usuarios",
    "db:categorias": "node scripts/ver-registros.js categorias",
    "db:productos": "node scripts/ver-registros.js productos",
    "db:carritos": "node scripts/ver-registros.js carritos",
    "db:detalles": "node scripts/ver-registros.js detalles",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.1",
    "mysql2": "^3.22.2",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.3"
